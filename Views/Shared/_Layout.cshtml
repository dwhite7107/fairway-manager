<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FairwayManager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FairwayManager.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-left">
                <a class="brand" asp-controller="Home" asp-action="Index">FairwayManager</a>

                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>

                @if (User.Identity.IsAuthenticated)
                {
                <a class="nav-link" asp-controller="Tournament" asp-action="Create">Create Tournament</a>
                <a class="nav-link" asp-controller="Tournament" asp-action="History"> My History</a>
                <a class="nav-link" asp-controller="Tournament" asp-action="EditProfile">Edit Profile</a>
                }


                <a class="nav-link" asp-controller="Tournament" asp-action="Browse">Browse Tournaments</a>

            </div>

            <div class="nav-right">
                <partial name="_LoginPartial" />
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
