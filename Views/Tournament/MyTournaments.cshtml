

@{
    ViewData["Title"] = "My Tournaments";
}

<div class="d-flex justify-content-center mt-4">
    <div style="max-width: 900px; width: 100%;">

        <h2 class="mb-4">My Tournaments</h2>

<style>
    .tournament-card {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 18px 22px;
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: 0.2s;
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .tournament-card:hover {
        transform: scale(1.01);
        background: rgba(255, 255, 255, 0.12);
    }

    .tournament-info strong {
        font-size: 1.1rem;
        color: white;
    }

    .tournament-info small {
        color: rgba(255,255,255,0.7);
    }

    .section-title {
        margin-top: 30px;
        margin-bottom: 10px;
        font-weight: 600;
        color: white;
    }
</style>


<!-- ACTIVE -->
<h4 style="color: #d4af37; font-weight: 600; margin-top: 25px;">
    Active
</h4>
<hr style="border-color: rgba(255,255,255,0.1); margin-top: 5px;" />

@if (ViewBag.Active.Count == 0)
{
    <p>No active tournaments.</p>
}
else
{
    @foreach (var t in ViewBag.Active)
    {
        <div class="tournament-card">
            <div class="tournament-info">

                <div style="font-weight: 600; font-size: 1.1rem; margin-bottom: 2px;">
                    @t.Name
                </div>

                <!-- ✅ DATE ADDED -->
                <div style="font-size: 0.85rem; opacity: 0.7;">
                    @t.Date.ToString("MMM dd, yyyy")
                </div>

                <div style="font-size: 0.85rem; opacity: 0.8;">
                    @(t.CourseName.Split(',')[0]) · @t.City, @t.State
                </div>

            </div>

            <a href="/Tournament/Leaderboard/@t.Id" class="btn btn-success btn-sm">View</a>
        </div>
    }
}

<!-- UPCOMING -->
<h4 style="color: #d4af37; font-weight: 600; margin-top: 25px;">
    Upcoming
</h4>
<hr style="border-color: rgba(255,255,255,0.1); margin-top: 5px;" />

@if (ViewBag.Upcoming.Count == 0)
{
    <p>No upcoming tournaments.</p>
}
else
{
    @foreach (var t in ViewBag.Upcoming)
    {
        <div class="tournament-card">
            <div class="tournament-info">

                <div style="font-weight: 600; font-size: 1.1rem; margin-bottom: 2px;">
                    @t.Name
                </div>

                <!-- ✅ DATE ADDED -->
                <div style="font-size: 0.85rem; opacity: 0.7;">
                    @t.Date.ToString("MMM dd, yyyy")
                </div>

                <div style="font-size: 0.85rem; opacity: 0.8;">
                    @(t.CourseName.Split(',')[0]) · @t.City, @t.State
                </div>

            </div>

            <a href="/Tournament/Details/@t.Id" class="btn btn-primary btn-sm">View</a>
        </div>
    }
}

<!-- COMPLETED -->
<h4 style="color: #d4af37; font-weight: 600; margin-top: 25px;">
    Completed
</h4>
<hr style="border-color: rgba(255,255,255,0.1); margin-top: 5px;" />

@if (ViewBag.Completed.Count == 0)
{
    <p>No completed tournaments.</p>
}
else
{
    @foreach (var t in ViewBag.Completed)
    {
        <div class="tournament-card">
            <div class="tournament-info">

                <div style="font-weight: 600; font-size: 1.1rem; margin-bottom: 2px;">
                    @t.Name
                </div>

                <!-- ✅ DATE ADDED -->
                <div style="font-size: 0.85rem; opacity: 0.7;">
                    @t.Date.ToString("MMM dd, yyyy")
                </div>

                <div style="font-size: 0.85rem; opacity: 0.8;">
                    @(t.CourseName.Split(',')[0]) · @t.City, @t.State
                </div>

            </div>

            <a href="/Tournament/Leaderboard/@t.Id" class="btn btn-secondary btn-sm">Results</a>
        </div>
    }
}
    </div>
</div>