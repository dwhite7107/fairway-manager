@{
    ViewData["Title"] = "Set Hole Pars";
}


        <style>
        .flash-success {
            border: 2px solid #28a745 !important;
            background-color: #e6ffed;
            transition: all 0.3s ease;
        }
        </style>

<h2>Set Hole Pars</h2>


    <input type="hidden" name="tournamentId" value="@ViewBag.TournamentId" />

    <div class="container">
    <div class="row">
        @for (int i = 0; i < ViewBag.HoleCount; i++)
        {
            <div class="col-md-4 mb-3"> <!-- 3 per row -->
                <div class="d-flex align-items-center gap-2">
                    <label style="width:70px;">Hole @(i + 1)</label>

                    @{
                        var holeNumber = i + 1;
                        var parsList = ViewBag.Pars as List<FairwayManager.Models.TournamentHolePar>;
                        var existingPar = parsList?.FirstOrDefault(p => p.HoleNumber == holeNumber);
                    }

                    <input type="number"
                        id="par-@i"
                        class="form-control"
                        style="width:70px;"
                        value="@(existingPar != null ? existingPar.Par : "")"
                        oninput="markDirty()" />
                </div>
            </div>
        }
    </div>
</div>


        <div class="mt-4">
            <button type="button" class="btn btn-primary btn-lg" onclick="saveAllPars()">
                💾 Save All Pars
            </button>
        </div>

        <div class="mt-4">
            <a href="/Tournament/Details/@ViewBag.TournamentId"
                class="btn btn-secondary"
                onclick="return confirmLeave()">
                ← Back to Tournament
            </a>
        </div>

<script>
let isDirty = false;

//  Track unsaved changes
function markDirty() {
    isDirty = true;
}

//  Save ONE hole
function savePar(index) {
    const input = document.getElementById(`par-${index}`);
    const value = input.value;

    if (value === "") return;

    fetch('/Tournament/SaveSinglePar', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            tournamentId: @ViewBag.TournamentId,
            holeNumber: index + 1,
            par: parseInt(value)
        })
    })
    .then(res => res.json())
    .then(data => {
        input.classList.add("flash-success");

        setTimeout(() => {
            input.classList.remove("flash-success");
        }, 800);

        // ✅ reset dirty after save
        isDirty = false;
    });
}

//  Save ALL holes
function saveAllPars() {
    const inputs = document.querySelectorAll('[id^="par-"]');

    inputs.forEach((input, index) => {
        if (input.value !== "") {
            setTimeout(() => {
                savePar(index);
            }, index * 200); 
        }
    });

    isDirty = false;

    alert("✅ All pars saved!");
}

//  Back button warning
function confirmLeave() {
    if (isDirty) {
        return confirm("Are you sure you want to leave without saving pars?");
    }
    return true;
}

//  Browser/tab close warning
window.addEventListener("beforeunload", function (e) {
    if (isDirty) {
        e.preventDefault();
        e.returnValue = '';
    }
});
</script>