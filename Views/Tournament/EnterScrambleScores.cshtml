@model FairwayManager.Models.Tournament

@{
    ViewData["Title"] = "Enter Scramble Scores";

    var allScores = (List<FairwayManager.Models.TeamScore>)ViewBag.TeamScores;

    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

    int currentRound = ViewBag.CurrentRound ?? 1;
}

<h2>Enter Scramble Scores - @Model.Name</h2>


<div class="mb-3">
    <strong style="color:#d4af37;">Round:</strong>

    @for (int i = 1; i <= Model.NumberOfRounds; i++)
    {
        <a href="@Url.Action("EnterScrambleScores", new { id = Model.Id, round = i })"
           class="btn btn-sm @(ViewBag.CurrentRound == i ? "btn-light" : "btn-outline-light")">
            @("Round " + i)
        </a>
    }
    <input type="hidden" id="roundSelect" value="@currentRound" />
</div>


@foreach (var tt in Model.TournamentTeams)
{
    var isOnTeam = tt.Team.PlayerTeams.Any(pt => pt.Player.UserId == currentUserId);
    if (!isOnTeam)
    {
        continue;
    }

    var teamScores = allScores?
        .Where(s => s.TeamId == tt.Team.Id && s.RoundNumber == currentRound)
        .ToList() ?? new List<FairwayManager.Models.TeamScore>();

    int total = teamScores
        .Where(s => s.RoundNumber == currentRound)
        .Sum(s => s.Strokes);

    int holesPlayed = teamScores
        .Where(s => s.RoundNumber == currentRound)
        .Count();

    <div class="card mb-4">
        <div class="card-header">
            <strong>@tt.Team.Name</strong>
        </div>

        <div class="card-body">

            <div class="mb-3">
                <div id="team-total-@tt.Team.Id">
                    Total: @total | Thru: @holesPlayed
                </div>
            </div>

            <div class="row">
                @for (int i = 1; i <= Model.HoleCount; i++)
                {
                    var saved = teamScores.FirstOrDefault(s =>
                        s.TeamId == tt.Team.Id &&
                        s.HoleNumber == i &&
                        s.RoundNumber == currentRound
                    );

                    <div class="col-2 mb-2 hole-container"
                         data-team="@tt.Team.Id"
                        data-hole="@(i)">

                        <label>Hole @i</label>

                        <input type="number"
                            
                            class="form-control scramble-input"
                            data-team="@tt.Team.Id"
                            data-hole="@(i)"
                            value="@(saved != null ? saved.Strokes : "")"
                            min="1" />

                        <button type="button"
                            class="btn btn-sm btn-primary mt-1 save-scramble-btn"
                            data-team="@tt.Team.Id"
                            data-hole="@(i)">
                            Save
                        </button>
                    </div>
                }
            </div>

        </div>
    </div>
}

<div class="d-flex gap-2 mt-4">
        <a href="/Tournament/Details/@Model.Id"
        class="btn btn-outline-light">
            ← Back to Tournament
        </a>

        <a href="/Tournament/Leaderboard/@Model.Id"
        class="btn btn-primary">
            View Leaderboard
        </a>
    </div>



@section Scripts {
<script>

// ✅ ROUND SWITCH (clean redirect)
const roundSelect = document.getElementById("roundSelect");

if (roundSelect) {
    roundSelect.addEventListener("change", function () {
        const round = this.value;
        const tournamentId = @Model.Id;

        window.location.href = `/Tournament/EnterScrambleScores/${tournamentId}?round=${round}`;
    });
}


// ✅ SAVE HOLE (NO REFRESH)
document.querySelectorAll(".save-scramble-btn").forEach(button => {
    button.addEventListener("click", function () {

        console.log("SAVE CLICKED");

        const container = this.closest(".hole-container");

        const teamId = container.dataset.team;
        const holeNumber = container.dataset.hole;
        const roundNumber = document.getElementById("roundSelect")?.value || 1;

        const input = container.querySelector("input");
        const strokes = input.value;

        fetch('/Tournament/SaveScrambleHole', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: new URLSearchParams({
                tournamentId: @Model.Id,
                teamId: teamId,
                holeNumber: holeNumber,
                strokes: strokes,
                roundNumber: roundNumber
            })
        })
        .then(res => {
            if (!res.ok) throw new Error("Request failed");
            return res.json();
        })
        .then(data => {
            if (data.success) {

                // visual feedback
                input.style.border = "2px solid limegreen";

                // animation
                animatePin(teamId, holeNumber);

                // update totals
                updateTeamTotal(teamId);
            }
        })
        .catch(err => console.error("ERROR:", err));
        })
    });


// ✅ LIVE TOTAL UPDATE (matches other modes)
function updateTeamTotal(teamId) {

    const inputs = document.querySelectorAll(`.hole-container[data-team='${teamId}'] input`);

    let total = 0;
    let count = 0;

    inputs.forEach(input => {
        if (input.value) {
            total += parseInt(input.value);
            count++;
        }
    });

    const totalDisplay = document.getElementById(`team-total-${teamId}`);
    totalDisplay.innerText = `Total: ${total} | Thru ${count}`;
}

function animatePin(playerId, holeIndex) {
    const target = document.getElementById(`score-${playerId}-${holeIndex}`);
    if (!target) return;

    const pin = document.createElement("div");
    pin.innerHTML = "⛳";
    pin.style.position = "fixed";
    pin.style.fontSize = "24px";
    pin.style.zIndex = 9999;

    document.body.appendChild(pin);

    const rect = target.getBoundingClientRect();

    pin.style.left = rect.left + "px";
    pin.style.top = "0px";

    pin.animate([
        { transform: "translateY(0px)", opacity: 1 },
        { transform: `translateY(${rect.top}px)`, opacity: 1 },
        { transform: `translateY(${rect.top + 10}px)`, opacity: 0 }
    ], {
        duration: 600,
        easing: "ease-out"
    });

    setTimeout(() => pin.remove(), 600);
}

</script>
}