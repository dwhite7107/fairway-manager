@model List<FairwayManager.Models.TournamentActivity>

@if (Model.Count == 0)
{
    <p>No activity yet.</p>
}
else
{
    <ul class="list-group">
        @foreach (var a in Model)
        {
            <li class="list-group-item">
                <small style="opacity: 0.6;">
                    @a.CreatedAt.ToString("MMM dd, HH:mm")
                </small><br />
                @a.Message
            </li>
        }
    </ul>
}