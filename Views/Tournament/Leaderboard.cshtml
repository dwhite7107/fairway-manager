@model List<dynamic>

@{
    ViewData["Title"] = "Leaderboard";
}

<style>
.tournament-info-bar {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

.info-chip {
    background-color: #1f4d2e; /* dark green */
    padding: 12px 18px;
    border-radius: 10px;
    min-width: 150px;
}

.info-chip .label {
    font-size: 12px;
    color: #cbd5e1;
    margin-bottom: 3px;
}

.info-chip .value {
    font-size: 16px;
    font-weight: bold;
    color: white;
}

<style>
.gold-row {
    background: linear-gradient(to right, rgba(212,175,55,0.25), transparent);
    font-weight: 600;
}

.silver-row {
    background: linear-gradient(to right, rgba(192,192,192,0.2), transparent);
}

.bronze-row {
    background: linear-gradient(to right, rgba(205,127,50,0.2), transparent);
}

</style>

<div class="leaderboard-container">

    <h2 class="leaderboard-title">Leaderboard </h2>

    <div class="tournament-info-bar mt-3 mb-4">
        <div class="info-chip">
            <div class="label">Tournament</div>
            <div class="value">@ViewBag.TournamentName</div>
        </div>

        <div class="info-chip">
            <div class="label">Course</div>
            <div class="value">@ViewBag.CourseName</div>
        </div>

        <div class="info-chip">
            <div class="label">Format</div>
            <div class="value">@ViewBag.ScoringType</div>
        </div>

        <div class="info-chip">
            <div class="label">Date</div>
            <div class="value">@ViewBag.Date</div>
        </div>
    </div>

@if (ViewBag.TotalRounds > 1)
{
    <div class="mb-3">
        <strong>View:</strong>

        <a class="btn btn-sm @(ViewBag.SelectedRound == 0 ? "btn-light" : "btn-outline-light")"
        href="@Url.Action("Leaderboard", new { id = ViewContext.RouteData.Values["id"] })">
            Total
        </a>

        @for (int i = 1; i <= (int)ViewBag.TotalRounds; i++)
        {
            <a class="btn btn-sm @(ViewBag.SelectedRound == i ? "btn-light" : "btn-outline-light")"
            href="@Url.Action("Leaderboard", new { id = ViewContext.RouteData.Values["id"], round = i })">
                Round @i
            </a>
        }
    </div>
}

    <table class="leaderboard-table">
        <thead>
            <tr>
                <th>Rank</th>
                <th>Player / Team</th>
                <th>Thru</th>
                <th>Total</th>
                <th>To Par</th>
            </tr>
        </thead>
        <tbody id="leaderboard-body">
            @Html.Partial("_LeaderboardRows", Model)
        </tbody>
    </table>

</div>

<div class="d-flex gap-2 mt-4">
    <a asp-action="Details"
       asp-route-id="@ViewContext.RouteData.Values["id"]"
       class="btn btn-outline-light">
        ← Back to Tournament
    </a>

    @{
        var tournament = ViewBag.Tournament;

        var endDate = tournament.Date.AddDays(tournament.NumberOfRounds - 1);
        var isCompleted = DateTime.Today > endDate;
    }

    @if (!isCompleted)
    {
        <a asp-action="EnterScores"
        asp-route-id="@ViewContext.RouteData.Values["id"]"
        class="btn btn-primary">
            ✏️ Enter Scores
        </a>
    }
</div>

<script>
    async function refreshLeaderboard() {
        const id = window.location.pathname.split("/").pop();

        const response = await fetch(`/Tournament/LeaderboardPartial?id=${id}`);
        const html = await response.text();

        document.getElementById("leaderboard-body").innerHTML = html;
    }

    setInterval(refreshLeaderboard, 5000);
</script>