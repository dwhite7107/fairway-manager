@model List<dynamic>

@{
    ViewData["Title"] = "Leaderboard";
}

<style>
.tournament-info-bar {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

.info-chip {
    background-color: #1f4d2e; /* dark green */
    padding: 12px 18px;
    border-radius: 10px;
    min-width: 150px;
}

.info-chip .label {
    font-size: 12px;
    color: #cbd5e1;
    margin-bottom: 3px;
}

.info-chip .value {
    font-size: 16px;
    font-weight: bold;
    color: white;
}
</style>

<div class="leaderboard-container">

    <h2 class="leaderboard-title">Leaderboard </h2>

    <div class="tournament-info-bar mt-3 mb-4">
        <div class="info-chip">
            <div class="label">Tournament</div>
            <div class="value">@ViewBag.TournamentName</div>
        </div>

        <div class="info-chip">
            <div class="label">Course</div>
            <div class="value">@ViewBag.CourseName</div>
        </div>

        <div class="info-chip">
            <div class="label">Format</div>
            <div class="value">@ViewBag.ScoringType</div>
        </div>

        <div class="info-chip">
            <div class="label">Date</div>
            <div class="value">@ViewBag.Date</div>
        </div>
    </div>


<div class="mb-3">
    <strong>View:</strong>

    <a class="btn btn-sm @(ViewBag.SelectedRound == 0 ? "btn-primary" : "btn-outline-primary")"
       href="@Url.Action("Leaderboard", new { id = ViewContext.RouteData.Values["id"] })">
        Total
    </a>

    @for (int i = 1; i <= (int)ViewBag.TotalRounds; i++)
    {
        <a class="btn btn-sm @(ViewBag.SelectedRound == i ? "btn-primary" : "btn-outline-primary")"
           href="@Url.Action("Leaderboard", new { id = ViewContext.RouteData.Values["id"], round = i })">
            Round @i
        </a>
    }
</div>

    <table class="leaderboard-table">
        <thead>
            <tr>
                <th>Rank</th>
                <th>Player / Team</th>
                <th>Thru</th>
                <th>Total</th>
                <th>To Par</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="rank">@item.Rank</td>
                    <td class="player">@item.Name</td>
                    <td>@item.Thru</td>
                    <td>@item.Total</td>
                    <td class="to-par @(item.ToPar < 0 ? "under" : item.ToPar > 0 ? "over" : "even")">
                        @(item.ToPar == 0 ? "E" : item.ToPar > 0 ? "+" + item.ToPar : item.ToPar.ToString())
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

<div class="d-flex gap-2 mt-4">
    <a asp-action="Details"
       asp-route-id="@ViewContext.RouteData.Values["id"]"
       class="btn btn-outline-light">
        ← Back to Tournament
    </a>

    @{
        var tournament = ViewBag.Tournament;

        var endDate = tournament.Date.AddDays(tournament.NumberOfRounds - 1);
        var isCompleted = DateTime.Today > endDate;
    }

    @if (!isCompleted)
    {
        <a asp-action="EnterScores"
        asp-route-id="@ViewContext.RouteData.Values["id"]"
        class="btn btn-primary">
            ✏️ Enter Scores
        </a>
    }
</div>