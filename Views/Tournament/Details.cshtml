@model FairwayManager.Models.Tournament


@using System.Security.Claims

@{
    ViewData["Title"] = "Tournament Details";

    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isLoggedIn = User.Identity.IsAuthenticated;

    bool alreadyJoined = Model.TournamentPlayers != null &&
        Model.TournamentPlayers.Any(tp => tp.Player.UserId == currentUserId);

    bool userAlreadyOnTeam = Model.TournamentTeams != null &&
        Model.TournamentTeams.Any(tt =>
            tt.Team.PlayerTeams.Any(pt => pt.Player.UserId == currentUserId));

    var isCreator = currentUserId == Model.CreatorId;

    
}




<div class="tournament-details">

@{
    var today = DateTime.Now.Date;

    var startDate = Model.Date.AddHours(6).Date;
    var endDate = startDate.AddDays(Model.NumberOfRounds - 1);

    string status;

    if (today < startDate)
    {
        status = "Upcoming";
    }
    else if (today > endDate)
    {
        status = "Completed";
    }
    else
    {
        status = "In Progress";
    }
}



    <!-- HEADER -->
    <div class="details-header">
        <div>
            <h1>@Model.Name</h1>

            <div class="info-row">
                <div class="info-chip">
                    <span>Course</span>
                    @{
                        var cleanName = Model.CourseName?.Split(',')[0];
                    }

                    <strong>
                        @(string.IsNullOrEmpty(Model.City)
                            ? cleanName
                            : $"{cleanName} · {Model.City}, {Model.State}")
                    </strong>
                </div>

                <div class="info-chip">
                    <span>Date</span>
                    <strong>@Model.Date.ToString("MMMM d")</strong>
                </div>

                <div class="info-chip">
                    <span>Status</span>
                    <strong class="status-text">
                        @status
                    </strong>
                </div>

                <div class="info-chip">
                    <span>Holes</span>
                    <strong>@Model.HoleCount</strong>
                </div>

                <div class="info-chip">
                    <span>Format</span>
                    <strong>
                        @(Model.ScoringType == "BestBall" ? "Best Ball" :
                        Model.ScoringType == "StrokePlay" ? "Stroke Play" :
                        Model.ScoringType)
                    </strong>
                </div>



            </div>
        </div>

        @if (User.Identity.IsAuthenticated)
        {
            <span class="badge bg-success px-3 py-2" style="font-size: 0.9rem;">
                ✓ Joined
            </span>
        }
    </div>

    
    <!-- JOIN CODE (CREATOR ONLY) -->
    @if (User.Identity.IsAuthenticated && isCreator)
    {
        <div class="join-code-box">
            <span>Join Code</span>

            <!-- ✅ ADD THIS LINE -->
            <p class="text-muted mb-2" style="font-size: 0.9rem;">
                This is your tournament’s join code. Share it with players so they can join.
            </p>

            <div class="code-row">
                <h2 id="joinCode">@Model.JoinCode</h2>
                <button onclick="copyCode()" class="btn-copy">Copy</button>
            </div>
        </div>
    }

    <!-- JOIN FORM -->
    @if (!alreadyJoined)
    {
        <div class="details-card mb-4">
            <h3>Join Tournament</h3>

            @if (!string.IsNullOrEmpty(Model.Qualifications))
            {
                <p class="text-warning mb-2" style="font-size: 0.95rem;">
                    <strong>Qualifications:</strong> @Model.Qualifications
                </p>
            }

            @if (isCreator)
            {
                <p class="text-muted mb-2" style="font-size: 0.9rem;">
                    You are the organizer. Join this tournament only if you plan to participate.
                </p>
            }
            else
            {
                <p class="text-muted mb-2" style="font-size: 0.9rem;">
                    You’ll need a join code to enter this tournament.
                    Contact the tournament creator to receive one.
                </p>
            }

            @if (User.Identity.IsAuthenticated && !alreadyJoined)
            {
                <!-- NORMAL JOIN FORM -->
                <form asp-action="Join" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <input type="text"
                        name="code"
                        placeholder="Enter join code"
                        class="form-input"
                        required />

                    <button type="submit" class="btn btn-gold mt-2">
                        Join Tournament
                    </button>
                </form>
            }
            else
            {
                <!-- NOT LOGGED IN -->
                <a asp-area="Identity"
                asp-page="/Account/Register"
                asp-route-returnUrl="@Url.Action("Details", "Tournament", new { id = Model.Id })"
                asp-route-message="join"
                class="btn btn-warning mt-2">
                    Join Tournament
                </a>
            }
        </div>
    }
        <!-- MAIN GRID -->
        <div class="details-grid">

            <!-- PLAYERS -->
            @if (alreadyJoined)
            {
                <div class="details-card">
                    <h3>Players</h3>

                    @if (Model.TournamentPlayers == null || !Model.TournamentPlayers.Any())
                    {
                        <p>No players yet.</p>
                    }
                    else
                    {
                        @foreach (var tp in Model.TournamentPlayers)
                        {
                            <div class="player-row">
                                ⛳ @tp.Player.Name
                            </div>
                        }
                    }
                </div>
            }

            <!-- TEAMS -->
            @if (isLoggedIn && alreadyJoined && Model.IsTeamBased)
            {
                <div class="details-card">

                    <div class="card-header">
                        <h3>Teams</h3>

                        @if (!userAlreadyOnTeam)
                        {
                            <a asp-controller="Team"
                               asp-action="Create"
                               asp-route-tournamentId="@Model.Id"
                               class="btn btn-gold">
                                Create Team
                            </a>
                        }
                    </div>

                    @if (Model.TournamentTeams == null || !Model.TournamentTeams.Any())
                    {
                        <p>No teams yet.</p>
                    }
                    else
                    {
                        @foreach (var tt in Model.TournamentTeams)
                        {
                            <div class="team-card">

                                <div style="font-size: 1.2rem; font-weight: 600; color: #d4af37;">
                                    @tt.Team.Name
                                </div>

                                <div class="team-players">
                                    @foreach (var pt in tt.Team.PlayerTeams)
                                    {
                                        <div>• @pt.Player.Name</div>
                                    }
                                </div>

                                @if (!userAlreadyOnTeam)
                                {
                                    <form asp-controller="Team" asp-action="Join" method="post">
                                        <input type="hidden" name="teamId" value="@tt.Team.Id" />
                                        <input type="hidden" name="tournamentId" value="@Model.Id" />

                                        <button type="submit" class="btn btn-secondary mt-2">
                                            Join Team
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="badge bg-success mt-2">
                                        Already on a team
                                    </span>
                                }

                            </div>
                        }
                    }

                </div>
            }

        </div>

    <div class="action-bar mb-3">

        @if (isLoggedIn && isCreator)
        {
            @if (!Model.IsTeamBased)
            {
                <a asp-action="ManagePlayers" asp-route-id="@Model.Id" class="btn-action">
                    👥 Manage Players
                </a>
            }

            @if (Model.IsTeamBased)
            {
                <a asp-action="ManageTeams" asp-route-id="@Model.Id" class="btn-action">
                    👥 Manage Teams
                </a>
            }

            <a asp-action="SetPars" asp-route-id="@Model.Id" class="btn-action">
                ⛳ Set Pars
            </a>
        }

        @if (isLoggedIn && alreadyJoined && status == "In Progress")
        {
            <a asp-action="EnterScores" asp-route-id="@Model.Id" class="btn-action">
                ⛳ Enter Scores
            </a>
        }

        @if (User.Identity.IsAuthenticated)
        {
            <a asp-action="Leaderboard" asp-route-id="@Model.Id" class="btn-primary big">
                🏆 View Leaderboard
            </a>
        }
        
        @if (User.Identity.IsAuthenticated && (alreadyJoined || isCreator))
        {
            <button class="btn-action" onclick="copyTournamentLink()">
                🔗 Share Tournament
            </button>
        }

    </div>
    
    
    
    <div class="mt-4">
        <h4>Activity</h4>

        <div id="activityFeed" class="activity-box">
            @await Html.PartialAsync("_ActivityFeed", (List<FairwayManager.Models.TournamentActivity>)ViewBag.Activity)
        </div>
    </div>
    

    <br />

    <a asp-action="Index" class="btn btn-outline-light">
        Back to Tournaments
    </a>

</div>

<div id="copyToast" class="copy-toast">
    ✅ Link copied!
</div>

@section Scripts {
<script>
    function copyCode() {
        const code = document.getElementById("joinCode").innerText;
        navigator.clipboard.writeText(code);
    }

    function copyTournamentLink() {
        const url = window.location.href;

        navigator.clipboard.writeText(url).then(() => {
            const toast = document.getElementById("copyToast");

            toast.classList.add("show");

            setTimeout(() => {
                toast.classList.remove("show");
            }, 2000);
        }).catch(err => {
            console.error("Failed to copy: ", err);
        });
    }

    // 🔥 ADD THIS
    function loadActivity() {
        fetch('/Tournament/GetActivity/@Model.Id')
            .then(res => res.text())
            .then(html => {
                document.getElementById("activityFeed").innerHTML = html;
            })
            .catch(err => console.error(err));
    }

    // refresh every 5 seconds
    setInterval(loadActivity, 5000);

    // load immediately on page load
    loadActivity();
</script>
}