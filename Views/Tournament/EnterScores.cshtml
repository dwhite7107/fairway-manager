@model FairwayManager.Models.Tournament

@{
    ViewData["Title"] = "Enter Scores";
    var tournamentPlayers = ViewBag.TournamentPlayers as IEnumerable<FairwayManager.Models.TournamentPlayer>;
    var scores = ViewBag.Scores as List<FairwayManager.Models.Score>;
}

<h2>Enter Scores - @Model.Name</h2>


<div class="mb-3">
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">
        Back to Tournament
    </a>

    <a asp-action="Leaderboard" asp-route-id="@Model.Id" class="btn btn-info">
        View Leaderboard
    </a>
</div>

<!-- ✅ NEW: Round Selector -->
<div class="mb-3">
    <label for="roundSelect"><strong>Select Round:</strong></label>
    <select id="roundSelect" class="form-control" style="max-width:200px;">
        @for (int r = 1; r <= Model.NumberOfRounds; r++)
        {
            <option value="@r">Round @r</option>
        }
    </select>
</div>

@if (tournamentPlayers != null && tournamentPlayers.Any())
{
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

    foreach (var tp in tournamentPlayers.Where(tp => tp.Player.UserId == currentUserId))
    {
        <div class="card mb-3">
            <div class="card-header">
                <strong>@tp.Player.Name</strong>
            </div>

            <div class="card-body">

                <div class="mb-2">
                    <strong>Total:</strong> 
                    <span class="player-total" data-player="@tp.Player.Id">0</span> |
                    <strong>Thru:</strong> 
                    <span class="player-thru" data-player="@tp.Player.Id">0</span>
                </div>

                <div class="row">
                    @for (int i = 1; i <= Model.HoleCount; i++)
                    {
                        <div class="col-md-2 mb-2">
                            <label>Hole @i</label>

                            <input type="number"
                                   class="form-control score-input"
                                   data-player="@tp.Player.Id"
                                   data-hole="@i"
                                   data-round="1"
                                   value=""
                                   min="1" />

                            <button type="button"
                                    class="btn btn-sm btn-primary mt-1 save-hole-btn"
                                    data-player="@tp.Player.Id"
                                    data-hole="@i"
                                    data-round="1">
                                Save
                            </button>
                        </div>
                    }
                </div>

            </div>
        </div>
    }
}

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const allScores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            ((List<FairwayManager.Models.Score>)ViewBag.Scores).Select(s => new {
                playerId = s.PlayerId,
                holeNumber = s.HoleNumber,
                strokes = s.Strokes,
                roundNumber = s.RoundNumber
            })
        ));
        console.log("ALL SCORES:", allScores);

        let currentRound = 1;

        document.getElementById("roundSelect").addEventListener("change", function () {
            currentRound = parseInt(this.value);
            loadRoundData();
        });

        function updateTotals(playerId) {
            let inputs = document.querySelectorAll(`.score-input[data-player='${playerId}']`);
            let total = 0;
            let thru = 0;

            inputs.forEach(input => {
                let val = parseInt(input.value);
                if (!isNaN(val)) {
                    total += val;
                    thru++;
                }
            });

            document.querySelector(`.player-total[data-player='${playerId}']`).innerText = total;
            document.querySelector(`.player-thru[data-player='${playerId}']`).innerText = thru;
        }

        function loadRoundData() {
            console.log("LOAD ROUND DATA RUNNING");

            // ✅ STEP 1: CLEAR EVERYTHING FIRST
            document.querySelectorAll(".score-input").forEach(input => {
                input.value = "";
                input.classList.remove("saved");
            });

            // ✅ STEP 2: LOAD ONLY MATCHING ROUND DATA
            document.querySelectorAll(".score-input").forEach(input => {

                let playerId = parseInt(input.dataset.player);
                let hole = parseInt(input.dataset.hole);

                console.log("Checking:", playerId, hole, currentRound);

                let match = allScores.find(s =>
                    s.playerId == playerId &&
                    s.holeNumber == hole &&
                    s.roundNumber == currentRound
                );

                if (match) {
                    input.value = match.strokes;
                    input.classList.add("saved");
                }

                // update dataset for saving
                input.dataset.round = currentRound;
            });

            // update buttons
            document.querySelectorAll(".save-hole-btn").forEach(btn => {
                btn.dataset.round = currentRound;
            });

            // recalc totals
            document.querySelectorAll(".player-total").forEach(el => {
                let playerId = el.dataset.player;
                updateTotals(playerId);
            });
        }
        

        document.querySelectorAll(".score-input").forEach(input => {
            input.addEventListener("input", function () {
                let playerId = this.dataset.player;
                updateTotals(playerId);
            });
        });

document.querySelectorAll(".save-hole-btn").forEach(button => {
    button.addEventListener("click", function () {

        let playerId = this.dataset.player;
        let hole = this.dataset.hole;
        let round = this.dataset.round;

        let input = document.querySelector(`.score-input[data-player='${playerId}'][data-hole='${hole}']`);
        let strokes = input.value;

        console.log("SAVING:", playerId, hole, strokes, round);
        fetch('/Tournament/SaveHoleScore', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: new URLSearchParams({
                tournamentId: @Model.Id,
                playerId: playerId,
                holeNumber: hole,
                strokes: strokes,
                roundNumber: parseInt(round)
            })
        })
        .then(response => {
            if (response.ok) {
                input.classList.add("saved");

                let existing = allScores.find(s =>
                    s.playerId == playerId &&
                    s.holeNumber == hole &&
                    s.roundNumber == round
                );

                if (existing) {
                    existing.strokes = parseInt(strokes);
                } else {
                    allScores.push({
                        playerId: parseInt(playerId),
                        holeNumber: parseInt(hole),
                        strokes: parseInt(strokes),
                        roundNumber: parseInt(round)
                    });
                }

                updateTotals(playerId);
            }
        });

    });
});

// ✅ THIS MUST BE OUTSIDE EVERYTHING
loadRoundData();

}); // ✅ closes DOMContentLoaded
</script>
}