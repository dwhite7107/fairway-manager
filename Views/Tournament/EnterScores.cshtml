@model FairwayManager.Models.Tournament

@{
    ViewData["Title"] = "Enter Scores";
    var tournamentPlayers = ViewBag.TournamentPlayers as IEnumerable<FairwayManager.Models.TournamentPlayer>;
    var scores = ViewBag.Scores as List<FairwayManager.Models.Score>;
}

<h2>Enter Scores - @Model.Name</h2>



<div class="mb-3">
    <strong style="color:#d4af37;">Round:</strong>

    @for (int i = 1; i <= Model.NumberOfRounds; i++)
    {
        <a href="@Url.Action("EnterScores", new { id = Model.Id, round = i })"
           class="btn btn-sm @(ViewBag.CurrentRound == i ? "btn-light" : "btn-outline-light")">
            @("Round " + i)
        </a>
    }
</div>


@if (tournamentPlayers != null && tournamentPlayers.Any())
{
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

    foreach (var tp in tournamentPlayers.Where(tp => tp.Player.UserId == currentUserId))
    {
        <div class="card mb-3">
            

            <div class="card-body">

                <div class="mb-2">
                    <div style="font-size: 1.5rem; font-weight: 600;">
                        @tp.Player.Name
                    </div>

                    <div style="font-size: 1.2rem; opacity: 0.9;">
                        Total: <span class="player-total" data-player="@tp.Player.Id">0</span> |
                        Thru: <span class="player-thru" data-player="@tp.Player.Id">0</span>
                    </div>
                </div>

                <div class="row">
                    @for (int i = 1; i <= Model.HoleCount; i++)
                    {
                        
                            var saved = scores.FirstOrDefault(s =>
                                s.PlayerId == tp.Player.Id &&
                                s.HoleNumber == i &&
                                s.RoundNumber == ViewBag.CurrentRound
                            );
                        

                        <div class="col-md-2 mb-2">
                            <label>Hole @i</label>

                            <input type="number"
                                id="score-@tp.Player.Id-@(i)"
                                class="form-control score-input"
                                data-player="@tp.Player.Id"
                                data-hole="@(i)"
                                data-round="@ViewBag.CurrentRound"
                                value="@(saved != null ? saved.Strokes : "")"
                                min="1" />

                            <button type="button"
                                    class="btn btn-sm btn-primary mt-1 save-hole-btn"
                                    data-player="@tp.Player.Id"
                                    data-hole="@(i)"
                                    data-round="@ViewBag.CurrentRound">
                                Save
                            </button>
                        </div>
                    }
                </div>

            </div>
        </div>
    }

    <div class="d-flex gap-2 mt-4">
        <a href="/Tournament/Details/@Model.Id"
        class="btn btn-outline-light">
            ← Back to Tournament
        </a>

        <a href="/Tournament/Leaderboard/@Model.Id"
        class="btn btn-primary">
            View Leaderboard
        </a>
    </div>
}

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function () {

        let allScores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            ((List<FairwayManager.Models.Score>)ViewBag.AllScores).Select(s => new {
                playerId = s.PlayerId,
                holeNumber = s.HoleNumber,
                strokes = s.Strokes,
                roundNumber = s.RoundNumber
            })
        ));

        console.log("ALL SCORES:", allScores);

        let currentRound = parseInt(@ViewBag.CurrentRound) || 1;

        const roundSelect = document.getElementById("roundSelect");

        if (roundSelect) {
            roundSelect.addEventListener("change", function () {
                currentRound = parseInt(this.value);
                loadRoundData();
            });
        }

        function updateTotals(playerId) {
            let inputs = document.querySelectorAll(`.score-input[data-player='${playerId}']`);
            let total = 0;
            let thru = 0;

            inputs.forEach(input => {
                let val = parseInt(input.value);
                if (!isNaN(val)) {
                    total += val;
                    thru++;
                }
            });

            document.querySelector(`.player-total[data-player='${playerId}']`).innerText = total;
            document.querySelector(`.player-thru[data-player='${playerId}']`).innerText = thru;
        }

        function loadRoundData() {
            console.log("LOAD ROUND DATA RUNNING");

            // ✅ STEP 1: CLEAR EVERYTHING FIRST
            document.querySelectorAll(".score-input").forEach(input => {
                input.value = "";
                input.classList.remove("saved");
            });

            // ✅ STEP 2: LOAD ONLY MATCHING ROUND DATA
            document.querySelectorAll(".score-input").forEach(input => {

                let playerId = parseInt(input.dataset.player);
                let hole = parseInt(input.dataset.hole);

                console.log("Checking:", playerId, hole, currentRound);

                let match = allScores.find(s =>
                    s.playerId === playerId &&
                    s.holeNumber === hole &&
                    s.roundNumber === parseInt(currentRound)
                );

                if (match) {
                    input.value = match.strokes;
                    input.classList.add("saved");
                }

                // update dataset for saving
                input.dataset.round = currentRound;
            });

            // update buttons
            document.querySelectorAll(".save-hole-btn").forEach(btn => {
                btn.dataset.round = currentRound;
            });

            // recalc totals
            document.querySelectorAll(".player-total").forEach(el => {
                let playerId = el.dataset.player;
                updateTotals(playerId);
            });
        }
        

        document.querySelectorAll(".score-input").forEach(input => {
            input.addEventListener("input", function () {
                let playerId = this.dataset.player;
                updateTotals(playerId);
            });
        });

document.querySelectorAll(".save-hole-btn").forEach(button => {
    button.addEventListener("click", function () {

        let playerId = parseInt(this.dataset.player);
        let hole = parseInt(this.dataset.hole);
        let round = currentRound || 1;

        let input = document.getElementById(`score-${playerId}-${hole}`);
        if (!input) return;

        let strokes = parseInt(input.value);


        console.log("INPUT VALUE:", input.value);
        console.log("PARSED:", strokes);
        if (isNaN(strokes)) {
            console.error("Invalid strokes");
            return;
        }

        console.log("SAVING:", playerId, hole, strokes, round);

        fetch('/Tournament/SaveHoleScore', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: new URLSearchParams({
                tournamentId: @Model.Id,
                playerId: playerId,
                holeNumber: hole,
                strokes: strokes,
                roundNumber: round
            })
        })
        .then(response => {
            if (response.ok) {

                input.classList.add("saved");

                animatePin(playerId, hole);

                let existing = allScores.find(s =>
                    s.playerId === playerId &&
                    s.holeNumber === hole &&
                    s.roundNumber === round
                );

                if (existing) {
                    existing.strokes = strokes;
                } else {
                    allScores.push({
                        playerId: playerId,
                        holeNumber: hole,
                        strokes: strokes,
                        roundNumber: round
                    });
                }
            }
        });

    });
});


    function animatePin(playerId, holeIndex) {
        const target = document.getElementById(`score-${playerId}-${holeIndex}`);
        if (!target) return;

        const pin = document.createElement("div");
        pin.innerHTML = "⛳";
        pin.style.position = "fixed";
        pin.style.fontSize = "24px";
        pin.style.zIndex = 9999;

        document.body.appendChild(pin);

        const rect = target.getBoundingClientRect();

        pin.style.left = rect.left + "px";
        pin.style.top = "0px";

        pin.animate([
            { transform: "translateY(0px)", opacity: 1 },
            { transform: `translateY(${rect.top}px)`, opacity: 1 },
            { transform: `translateY(${rect.top + 10}px)`, opacity: 0 }
        ], {
            duration: 600,
            easing: "ease-out"
        });

        setTimeout(() => pin.remove(), 600);
    }
// ✅ THIS MUST BE OUTSIDE EVERYTHING
loadRoundData();

}); // ✅ closes DOMContentLoaded
</script>
}