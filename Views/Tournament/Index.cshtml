@model IEnumerable<FairwayManager.Models.Tournament>

<div class="tournament-page">

    <!-- HEADER -->
    <div class="tournament-header">
        <h1>Tournaments</h1>
        <a asp-action="Create" class="btn btn-gold">Create New Tournament</a>
    </div>

    <!-- SEARCH -->
    <div class="search-container d-flex gap-2 mb-4">

        <input type="text"
            id="searchInput"
            class="form-control"
            placeholder="Search tournaments..." />

        @{
            var selectedStatus = Context.Request.Query["statusFilter"].ToString();
        }
        <form method="get">
            <select name="statusFilter" class="form-select" style="min-width: 200px;" onchange="this.form.submit()">

                <option value="" selected="@(string.IsNullOrEmpty(selectedStatus))">
                    All Status
                </option>

                <option value="Upcoming" selected="@(selectedStatus == "Upcoming")">
                    Upcoming
                </option>

                <option value="In Progress" selected="@(selectedStatus == "In Progress")">
                    In Progress
                </option>

                <option value="Completed" selected="@(selectedStatus == "Completed")">
                    Completed
                </option>

            </select>
        </form>

    </div>

    <!-- GRID -->
    <div class="tournament-grid" id="tournamentGrid">
        @foreach (var t in Model)
        {
            <div class="tournament-card" data-name="@t.Name.ToLower()">

                @{
                    var endDate = t.Date.AddDays(t.NumberOfRounds - 1);

                    string status;

                    if (DateTime.Today < t.Date)
                        status = "Upcoming";
                    else if (DateTime.Today <= endDate)
                        status = "In Progress";
                    else
                        status = "Completed";
                }

                <span class="status-badge @(status.ToLower().Replace(" ", ""))">
                    @status
                </span>

                <div class="card-body">

                    <!-- 🔥 TITLE (THIS FIXES YOUR ISSUE) -->
                    <h4 class="tournament-title">@t.Name</h4>

                    <p class="date">
                        @t.Date.ToString("MMMM dd, yyyy")
                    </p>

                    @if (!string.IsNullOrEmpty(t.City) && !string.IsNullOrEmpty(t.State))
                    {
                        <p class="location">
                            @t.CourseName · @t.City, @t.State
                        </p>
                    }
                    else if (!string.IsNullOrEmpty(t.CourseName))
                    {
                        <p class="location">
                            @t.CourseName
                        </p>
                    }


                    <p class="meta">
                        @t.PlayerCount players
                    </p>
                </div>

                <div class="card-footer">
                    <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-primary">
                        View Tournament
                    </a>
                </div>

            </div>
        }

        <div class="pagination-bar mt-4">

            @if (ViewBag.CurrentPage > 1)
            {
                <a class="btn btn-outline-light pagination-btn"
                asp-action="Index"
                asp-route-page="@(ViewBag.CurrentPage - 1)"
                asp-route-statusFilter="@Context.Request.Query["statusFilter"]">
                    ← Previous
                </a>
            }

            <span class="pagination-text">
                Page @ViewBag.CurrentPage of @ViewBag.TotalPages
            </span>

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a class="btn btn-outline-light pagination-btn"
                asp-action="Index"
                asp-route-page="@(ViewBag.CurrentPage + 1)"
                asp-route-statusFilter="@Context.Request.Query["statusFilter"]">
                    Next →
                </a>
            }

        </div>
    </div>

</div>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {

    const searchInput = document.getElementById("searchInput");
    const cards = document.querySelectorAll(".tournament-card");

    if (!searchInput) return;

    searchInput.addEventListener("input", function () {
        const query = this.value.toLowerCase();

        cards.forEach(card => {
            const name = card.getAttribute("data-name");

            if (name && name.includes(query)) {
                card.style.display = "";
            } else {
                card.style.display = "none";
            }
        });
    });

});
</script>
}