@model IEnumerable<FairwayManager.Models.Tournament>

<div class="tournament-page">

    <!-- HEADER -->
    <div class="tournament-header">
        <h1>Tournaments</h1>
        <a asp-action="Create" class="btn btn-gold">Create New Tournament</a>
    </div>

    <!-- SEARCH -->
    <div class="search-container d-flex gap-2 mb-4">

        <input type="text"
            id="searchInput"
            class="form-control"
            placeholder="Search tournaments..." />

        <select id="statusFilter" class="form-select" style="max-width: 180px;">
            <option value="">All Status</option>
            <option value="Upcoming">Upcoming</option>
            <option value="In Progress">In Progress</option>
            <option value="Completed">Completed</option>
        </select>

    </div>

    <!-- GRID -->
    <div class="tournament-grid" id="tournamentGrid">
        @foreach (var t in Model)
        {
            <div class="tournament-card" data-name="@t.Name.ToLower()">

                @{
                    var endDate = t.Date.AddDays(t.NumberOfRounds - 1);

                    string status;

                    if (DateTime.Today < t.Date)
                        status = "Upcoming";
                    else if (DateTime.Today <= endDate)
                        status = "In Progress";
                    else
                        status = "Completed";
                }

                <span class="status-badge @(status.ToLower().Replace(" ", ""))">
                    @status
                </span>

                <div class="card-body">

                    <!-- 🔥 TITLE (THIS FIXES YOUR ISSUE) -->
                    <h4 class="tournament-title">@t.Name</h4>

                    <p class="date">
                        @t.Date.ToString("MMMM dd, yyyy")
                    </p>

                    @if (!string.IsNullOrEmpty(t.City) && !string.IsNullOrEmpty(t.State))
                    {
                        <p class="location">
                            @t.CourseName · @t.City, @t.State
                        </p>
                    }
                    else if (!string.IsNullOrEmpty(t.CourseName))
                    {
                        <p class="location">
                            @t.CourseName
                        </p>
                    }


                    <p class="meta">
                        @t.PlayerCount players
                    </p>
                </div>

                <div class="card-footer">
                    <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-primary">
                        View Tournament
                    </a>
                </div>

            </div>
        }
    </div>

</div>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {

    const searchInput = document.getElementById("searchInput");
    const statusFilter = document.getElementById("statusFilter");
    const cards = document.querySelectorAll(".tournament-card");

    function filterTournaments() {

    if (!searchInput || !statusFilter) return;

    const searchValue = searchInput.value.toLowerCase();
    const statusValue = statusFilter.value.toLowerCase();

    cards.forEach(card => {

        // ✅ RESET FIRST (CRITICAL FIX)
        card.style.display = "block";

        const name = card.getAttribute("data-name");
        const status = card.querySelector(".status-badge").innerText.toLowerCase();

        const matchesSearch = name.includes(searchValue);
        const matchesStatus = !statusValue || status === statusValue;

        if (!(matchesSearch && matchesStatus)) {
            card.style.display = "none";
        }

    });
}

    // ONLY attach if elements exist
    if (searchInput) {
        searchInput.addEventListener("keyup", filterTournaments);
    }

    if (statusFilter) {
        statusFilter.addEventListener("change", filterTournaments);
    }

});
</script>
}