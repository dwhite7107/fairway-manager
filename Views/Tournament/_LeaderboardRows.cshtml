@foreach (var item in Model)
{
    <tr class="
        @(item.Rank == 1 ? "gold-row" :
          item.Rank == 2 ? "silver-row" :
          item.Rank == 3 ? "bronze-row" : "")
    ">
        <td>@item.Rank</td>
        <td>
            <a asp-controller="Tournament"
            asp-action="PlayerProfile"
            asp-route-id="@item.PlayerId"
            class="player-link">
                @item.Name
            </a>
        </td>
        <td>@((item.Thru ?? "").Replace("Thru ", ""))</td>
        <td>@item.Total</td>
        <td>@(item.ToPar == 0 ? "E" : item.ToPar > 0 ? "+" + item.ToPar : item.ToPar)</td>
    </tr>
}