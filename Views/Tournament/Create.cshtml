@model FairwayManager.Models.Tournament

@{
    ViewData["Title"] = "Create Tournament";
}

<div class="d-flex justify-content-center mt-5">
    <div class="card p-4 shadow" style="max-width: 700px; width: 100%; background-color: rgba(10, 40, 20, 0.9); border: 1px solid rgba(255,255,255,0.1);">

        <h2 class="mb-4 text-white">Create Tournament</h2>

        <form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <input asp-for="Description" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Qualifications</label>
        <input asp-for="Qualifications" class="form-control" placeholder="e.g. Invite only, 10 handicap or lower, etc." />
    </div>

    <div class="mb-3">
        <label class="form-label">Course</label>
        <input type="text" id="courseSearch" class="form-control" autocomplete="off" placeholder="Start typing course name..." />
        
        <div id="courseResults" class="list-group mt-1"></div>

        <small class="text-muted">Select a course from the list or enter manually</small>
    </div>

    

    <button type="button" id="manualEntryBtn" class="btn btn-link p-0 mb-3">
        Course not listed? Enter manually
    </button>

    <div id="manualFields" style="display:none;">
        <input type="text" id="manualCourse" class="form-control mb-2" placeholder="Course Name" />
        <input type="text" id="manualCity" class="form-control mb-2" placeholder="City" />
        <input type="text" id="manualState" class="form-control mb-2" placeholder="State" />
    </div>

    <!-- Hidden fields -->
    <input type="hidden" id="Course" name="CourseName" />
    <input type="hidden" id="City" name="City" />
    <input type="hidden" id="State" name="State" />
    <input type="hidden" id="Latitude" name="Latitude" />
    <input type="hidden" id="Longitude" name="Longitude" />

    <div class="form-group">
        <label asp-for="Date"></label>
        <input asp-for="Date" type="date" class="form-control" />
        <span asp-validation-for="Date" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HoleCount">Hole Count</label>
        <select asp-for="HoleCount" class="form-control">
            <option value="9">9</option>
            <option value="18">18</option>
        </select>
        <span asp-validation-for="HoleCount" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="NumberOfRounds">Number of Rounds</label>
        <select asp-for="NumberOfRounds" class="form-control">
            <option value="1">1 Round</option>
            <option value="2">2 Rounds</option>
            <option value="3">3 Rounds</option>
        </select>
    </div>

    <div class="form-group">
        <label>Event Type</label>
        <select asp-for="IsTeamBased" class="form-control" id="eventTypeDropdown">
            <option value="false">Individual Event</option>
            <option value="true">Team Event</option>
        </select>
    </div>

    <!-- Scoring Type Section -->
    <div class="form-group" id="scoringTypeSection">
        <label asp-for="ScoringType"></label>
        <select asp-for="ScoringType" class="form-control">
            <option value="">-- Select Scoring Type --</option>
            <option value="StrokePlay">Stroke Play</option>
            <option value="BestBall">Best Ball</option>
            <option value="Scramble">Scramble</option>
        </select>
        <span asp-validation-for="ScoringType" class="text-danger"></span>
    </div>

    <br />
    <button type="submit" class="btn" style="background-color: #d4af37; color: black; font-weight: 600;">
        Create Tournament
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // ===== EVENT TYPE TOGGLE =====
            const eventType = document.getElementById("eventTypeDropdown");
            const scoringSection = document.getElementById("scoringTypeSection");

            function toggleScoring() {
                if (eventType.value === "true") {
                    scoringSection.style.display = "block";
                } else {
                    scoringSection.style.display = "none";
                }
            }

            toggleScoring();
            eventType.addEventListener("change", toggleScoring);

            // ===== MANUAL ENTRY TOGGLE =====
            document.getElementById("manualEntryBtn").addEventListener("click", function () {
                document.getElementById("manualFields").style.display = "block";

                document.getElementById("Course").value = "";
                document.getElementById("City").value = "";
                document.getElementById("State").value = "";
                document.getElementById("Latitude").value = "";
                document.getElementById("Longitude").value = "";
            });

            // ===== LIVE SYNC: manual inputs → hidden fields =====
            document.getElementById("manualCourse").addEventListener("input", function () {
                document.getElementById("Course").value = this.value;
            });
            document.getElementById("manualCity").addEventListener("input", function () {
                document.getElementById("City").value = this.value;
            });
            document.getElementById("manualState").addEventListener("input", function () {
                document.getElementById("State").value = this.value;
            });

            // ===== NOMINATIM AUTOCOMPLETE =====
            let timeout = null;
            const cache = {};

            const courseInput = document.getElementById("courseSearch");
            const resultsDiv = document.getElementById("courseResults");

            if (courseInput) {
                courseInput.addEventListener("input", function () {
                    clearTimeout(timeout);

                    const query = this.value.trim();

                    timeout = setTimeout(() => {
                        if (query.length < 3) return;

                        if (cache[query]) {
                            displayResults(cache[query]);
                            return;
                        }

                        fetch(`https://nominatim.openstreetmap.org/search?` +
                            `q=${encodeURIComponent(query)}&` +
                            `format=json&` +
                            `limit=5&` +
                            `addressdetails=1&` +
                            `extratags=1`)
                        .then(res => res.json())
                        .then(data => {
                            const filtered = data.filter(place => {
                                const name = place.display_name.toLowerCase();
                                const golfKeywords = ["golf", "country club", "golf club", "national", "links", "resort", "course"];
                                return golfKeywords.some(keyword => name.includes(keyword));
                            });

                            cache[query] = filtered;
                            displayResults(filtered);
                        });
                    }, 500);
                });
            }

            function displayResults(data) {
                resultsDiv.innerHTML = "";

                if (data.length === 0) {
                    resultsDiv.innerHTML = `<div class="list-group-item">No results found</div>`;
                    return;
                }

                data.forEach(place => {
                    const item = document.createElement("a");
                    item.classList.add("list-group-item", "list-group-item-action");
                    item.textContent = place.display_name;

                    item.onclick = () => {
                        const address = place.address || {};
                        const parts = place.display_name.split(",");

                        document.getElementById("courseSearch").value = parts[0].trim();
                        document.getElementById("Course").value = parts[0].trim();
                        document.getElementById("City").value = address.city || address.town || address.village || address.hamlet || address.county || "";
                        document.getElementById("State").value = address.state || "";
                        document.getElementById("Latitude").value = place.lat;
                        document.getElementById("Longitude").value = place.lon;

                        resultsDiv.innerHTML = "";
                    };

                    resultsDiv.appendChild(item);
                });
            }

            // ===== FORM SUBMIT: final safety sync =====
            document.querySelector("form").addEventListener("submit", function () {
                const manualFieldsVisible = document.getElementById("manualFields").style.display !== "none";

                if (manualFieldsVisible) {
                    document.getElementById("Course").value = document.getElementById("manualCourse").value;
                    document.getElementById("City").value = document.getElementById("manualCity").value;
                    document.getElementById("State").value = document.getElementById("manualState").value;
                }
            });

        }); // end DOMContentLoaded
    </script>
}

